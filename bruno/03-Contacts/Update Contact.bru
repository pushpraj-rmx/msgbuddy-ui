meta {
  name: Update Contact
  type: http
  seq: 4
}

put {
  url: {{baseUrl}}/api/contacts/:id
  body: json
}

params:path {
  id: clx_contact_123
}

headers {
  Authorization: {{token}}
  Content-Type: application/json
}

body:json {
  {
    "name": "Jane Smith",
    "email": "jane.smith@example.com"
  }
}
